# Ignore huge model weights only
models/bestonemoreresnetlstm.pth

# Ignore all user-uploaded content, but keep the folders
uploads/
cam_inputs/*
processed_inputs/*
!cam_inputs/.gitkeep
!processed_inputs/.gitkeep

# Ignore the actual frames and landmarks generated during runtime
processed_inputs/frames/*
processed_inputs/landmarks/*

# But do NOT ignore the .gitkeep files that hold the folders open
!processed_inputs/frames/.gitkeep
!processed_inputs/landmarks/.gitkeep

# Ignore system junk
__pycache__/
venv/
.DS_Store
instance/virtuotherapy.db

# Note: We are NOT ignoring *.pth or *.mp4 globally anymore 
# so that data.pth and sample_exercises stay in the repo.